<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title }} | Hero Cleaners — Logan, UT</title>
  <meta name="description" content="{{ description if description else title }}" />
  <link rel="canonical" href="https://herocleanersllc.com{{ page.url }}" />
  <meta property="og:title" content="{{ title }}" />
  <meta property="og:type" content="article" />
  <meta property="og:url" content="https://herocleanersllc.com{{ page.url }}" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Open+Sans:wght@400;600;700&display=swap" rel="stylesheet" />
  <style>
    :root{--red:#B71C1C;--red-dark:#8B0000;--red-light:#FFCDD2;--black:#1A1A1A;--charcoal:#2D2D2D;--gray:#757575;--off-white:#F9F6F4;--white:#FFFFFF;--border:#E8E0DD;}
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
    body{font-family:'Open Sans',Helvetica,Arial,sans-serif;color:var(--black);background:var(--white);line-height:1.72;}
    nav{background:var(--white);border-bottom:3px solid var(--red);padding:0 24px;display:flex;align-items:center;justify-content:space-between;height:68px;position:sticky;top:0;z-index:200;box-shadow:0 2px 12px rgba(183,28,28,0.08);}
    .nav-logo{display:flex;align-items:center;text-decoration:none;}
    .nav-logo .logo-text{font-family:'Bebas Neue',Impact,sans-serif;font-size:1.7rem;letter-spacing:0.04em;line-height:1;}
    .nav-logo .logo-text span.hero{color:var(--black);}
    .nav-logo .logo-text span.clean{color:var(--red);}
    .nav-links{display:flex;align-items:center;gap:20px;flex-wrap:wrap;}
    .nav-links a{color:var(--charcoal);text-decoration:none;font-size:0.85rem;font-weight:600;letter-spacing:0.03em;text-transform:uppercase;transition:color 0.15s;}
    .nav-links a:hover{color:var(--red);}
    .nav-phone{color:var(--red)!important;font-weight:700!important;}
    .nav-cta{background:var(--red)!important;color:var(--white)!important;padding:9px 20px;border-radius:4px;font-weight:700!important;}
    .nav-cta:hover{background:var(--red-dark)!important;}
    .breadcrumb-bar{background:var(--off-white);border-bottom:1px solid var(--border);padding:10px 32px;}
    .breadcrumb-bar a{color:var(--red);text-decoration:none;font-size:0.82rem;font-weight:600;}
    .breadcrumb-bar span{color:var(--gray);font-size:0.82rem;margin:0 6px;}
    .post-outer{max-width:820px;margin:0 auto;padding:52px 28px 96px;}
    .post-meta{display:flex;align-items:center;gap:12px;margin-bottom:18px;flex-wrap:wrap;}
    .meta-tag{background:var(--red-light);color:var(--red-dark);font-size:0.75rem;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;padding:4px 10px;border-radius:3px;}
    .meta-date{font-size:0.82rem;color:var(--gray);}
    h1{font-family:'Bebas Neue',Impact,sans-serif;font-size:clamp(2rem,5vw,3.2rem);letter-spacing:0.03em;line-height:1.1;color:var(--black);margin-bottom:32px;}
    .title-rule{width:56px;height:4px;background:var(--red);border-radius:2px;margin-bottom:36px;}
    .post-body{font-size:1.06rem;color:var(--charcoal);}
    .post-body h2{font-family:'Bebas Neue',Impact,sans-serif;font-size:1.7rem;letter-spacing:0.04em;color:var(--black);margin:44px 0 14px;border-left:4px solid var(--red);padding-left:14px;}
    .post-body h3{font-size:1.1rem;font-weight:700;color:var(--black);margin:30px 0 10px;}
    .post-body p{margin-bottom:20px;}
    .post-body ul,.post-body ol{margin:0 0 20px 24px;}
    .post-body li{margin-bottom:8px;}
    .post-body a{color:var(--red);text-decoration:underline;}
    .post-body strong{font-weight:700;color:var(--black);}
    .cta-box{background:var(--black);color:var(--white);border-radius:6px;padding:40px 40px 36px;margin-top:56px;position:relative;overflow:hidden;}
    .cta-box::before{content:'';position:absolute;top:0;left:0;width:6px;height:100%;background:var(--red);}
    .cta-box h3{font-family:'Bebas Neue',Impact,sans-serif;font-size:1.9rem;letter-spacing:0.04em;margin-bottom:10px;color:var(--white);}
    .cta-box h3 span{color:var(--red);}
    .cta-box p{color:rgba(255,255,255,0.78);margin-bottom:24px;font-size:0.97rem;line-height:1.6;}
    .cta-box .cta-actions{display:flex;gap:14px;flex-wrap:wrap;align-items:center;}
    .btn-primary{display:inline-block;background:var(--red);color:var(--white);padding:13px 30px;border-radius:4px;font-weight:700;text-decoration:none;font-size:0.95rem;transition:background 0.15s;}
    .btn-primary:hover{background:var(--red-dark);}
    .cta-phone-link{color:rgba(255,255,255,0.65);font-size:0.9rem;text-decoration:none;}
    footer{background:var(--black);color:rgba(255,255,255,0.5);text-align:center;padding:36px 24px;font-size:0.82rem;border-top:3px solid var(--red);}
    footer a{color:rgba(255,255,255,0.7);text-decoration:none;}
    .footer-logo{font-family:'Bebas Neue',Impact,sans-serif;font-size:1.3rem;letter-spacing:0.05em;margin-bottom:10px;color:var(--white);}
    .footer-logo span{color:var(--red);}
    @media(max-width:768px){.nav-links .hide-mobile{display:none;}.post-outer{padding:32px 18px 72px;}.cta-box{padding:28px 24px;}}
  </style>
</head>
<body>
  <nav>
    <a class="nav-logo" href="/website/"><div class="logo-text"><span class="hero">Hero </span><span class="clean">Cleaners</span></div></a>
    <div class="nav-links">
      <a href="/website/#services" class="hide-mobile">Services</a>
      <a href="/website/#areas" class="hide-mobile">Service Areas</a>
      <a href="/website/#reviews" class="hide-mobile">Reviews</a>
      <a href="/website/#faq" class="hide-mobile">FAQ</a>
      <a href="/about" class="hide-mobile">About Us</a>
      <a href="/blog">Blog</a>
      <a href="tel:4352770370" class="nav-phone hide-mobile">(435) 277-0370</a>
      <a href="/website/#book" class="nav-cta">Book Online</a>
    </div>
  </nav>
  <div class="breadcrumb-bar">
    <a href="/blog">← Blog</a>
    <span>/</span>
    <span>{{ title | truncate(60) }}</span>
  </div>
  <div class="post-outer">
    <div class="post-meta">
      <span class="meta-tag">Cache Valley Tips</span>
      {% if date %}<span class="meta-date">{{ date | readableDate }}</span>{% endif %}
    </div>
    <h1>{{ title }}</h1>
    <div class="title-rule"></div>
    <div class="post-body">{{ content | safe }}</div>
    <div class="cta-box">
      <h3>Ready for a <span>spotless home?</span></h3>
      <p>Hero Cleaners serves Logan, North Logan, Smithfield, Hyrum, Nibley, Providence, Hyde Park, and all of Cache Valley. Locally owned since 2019 — 4.9 stars and 7,800+ homes cleaned.</p>
      <div class="cta-actions">
        <a href="/website/#book" class="btn-primary">Book Online</a>
        <a href="tel:4352770370" class="cta-phone-link">or call (435) 277-0370</a>
      </div>
    </div>
  </div>
  <footer>
    <div class="footer-logo">Hero <span>Cleaners</span> LLC</div>
    <p>Logan, Utah · Cache Valley's Most Trusted Cleaning Team</p>
    <p style="margin-top:8px;"><a href="tel:4352770370">(435) 277-0370</a> · <a href="mailto:herocleanersinfo@gmail.com">herocleanersinfo@gmail.com</a> · <a href="/website/">herocleanersllc.com</a></p>
    <p style="margin-top:12px;font-size:0.75rem;">© 2026 Hero Cleaners LLC. All rights reserved.</p>
  </footer>
</body>
</html>
